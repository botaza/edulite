# File 1 of 3: .htaccess

# Prevent direct access to JSON files for security
<FilesMatch "\.(json)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Increase PHP upload limits (works only if PHP runs as Apache module - mod_php)
<IfModule mod_php.c>
    php_value upload_max_filesize 100M
    php_value post_max_size 110M
    php_value memory_limit 256M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# Prevent directory listing
Options -Indexes
